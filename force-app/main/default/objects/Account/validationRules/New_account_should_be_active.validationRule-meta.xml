<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>New_account_should_be_active</fullName>
    <active>false</active>
    <description>New account should be active</description>
    <errorConditionFormula>AND(
      isnew() ,
      NOT ispickval( Active__c , &apos;Yes&apos;)
    )</errorConditionFormula>
    <errorDisplayField>Active__c</errorDisplayField>
    <errorMessage>Newly created accounts should be in Active Status</errorMessage>
</ValidationRule>
