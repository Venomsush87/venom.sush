<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Aadhar_Number</fullName>
    <active>true</active>
    <errorConditionFormula>IF(LEN(Aadhar__c) != 12, true, false)</errorConditionFormula>
    <errorDisplayField>Aadhar__c</errorDisplayField>
    <errorMessage>Enter a 12 digit Aadhar number</errorMessage>
</ValidationRule>
