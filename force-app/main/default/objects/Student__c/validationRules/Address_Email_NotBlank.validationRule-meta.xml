<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Address_Email_NotBlank</fullName>
    <active>true</active>
    <errorConditionFormula>AND(!ISBLANK( Email__c ),  ISBLANK( Address__c )  )</errorConditionFormula>
    <errorDisplayField>Address__c</errorDisplayField>
    <errorMessage>Address should not be blank</errorMessage>
</ValidationRule>
