<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Send_email_notification_upon_creating</fullName>
        <ccEmails>sushantsalunkhe87@gmail.com</ccEmails>
        <description>Send email notification upon creating  a contact record</description>
        <protected>false</protected>
        <recipients>
            <field>Email</field>
            <type>email</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/Contact_Creation_Notification2</template>
    </alerts>
    <rules>
        <fullName>Contact Creation Notification</fullName>
        <actions>
            <name>Send_email_notification_upon_creating</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Contact.Email</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Contact.LastName</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <description>Contact record Creation Notification using WF rules</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>send an email notification to the contact person</fullName>
        <active>false</active>
        <criteriaItems>
            <field>Contact.Email</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <description>send an email notification to the contact person</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
