    <fieldUpdates>
        <fullName>Position_Status_field_update_to_Closed</fullName>
        <field>Position_Status__c</field>
        <literalValue>Closed</literalValue>
        <name>Position Status field update to Closed</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Assign a task to admin user</fullName>
        <actions>
            <name>A_new_position_has_been_assigned_to_you</name>
            <type>Task</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Position__c.Name</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Position__c.Position_Status__c</field>
            <operation>notEqual</operation>
            <value>Closed</value>
        </criteriaItems>
        <description>Assign a task to admin user</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>Reminder Position notification</fullName>
        <actions>
            <name>Send_a_email_notification_upon_creating_a_new_position</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Position__c.Name</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Position__c.HR_Email__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Position__c.Position_Status__c</field>
            <operation>notEqual</operation>
            <value>Closed</value>
        </criteriaItems>
        <description>New Position notification</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Reminder_10_days_before_the_Position_Close_date</name>
                <type>Alert</type>
            </actions>
            <offsetFromField>Position__c.Close_Date__c</offsetFromField>
            <timeLength>-10</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
        <workflowTimeTriggers>
            <actions>
                <name>Reminder_5_days_before_the_Position_Close_date</name>
                <type>Alert</type>
            </actions>
            <offsetFromField>Position__c.Close_Date__c</offsetFromField>
            <timeLength>-5</timeLength>
