        </workflowTimeTriggers>
        <workflowTimeTriggers>
            <actions>
                <name>Reminder_2_days_before_the_Position_Close_date</name>
                <type>Alert</type>
            </actions>
            <offsetFromField>Position__c.Close_Date__c</offsetFromField>
            <timeLength>-2</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
        <workflowTimeTriggers>
            <actions>
                <name>Reminder_0_days_before_the_Position_Close_date</name>
                <type>Alert</type>
            </actions>
            <offsetFromField>Position__c.Close_Date__c</offsetFromField>
            <timeLength>0</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
        <workflowTimeTriggers>
            <actions>
                <name>Position_Status_field_update_to_Closed</name>
                <type>FieldUpdate</type>
            </actions>
            <offsetFromField>Position__c.Close_Date__c</offsetFromField>
            <timeLength>0</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
